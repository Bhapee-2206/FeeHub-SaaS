# Server Port (Render sets this automatically)
PORT=5000

# MongoDB Connection String (use your Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/feehub?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (for receipt emails)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
